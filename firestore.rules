rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * 1. REGRA MESTRE DE ADMINISTRADOR (USUÁRIOS AUTENTICADOS)
     * Concede acesso TOTAL a qualquer pessoa logada no sistema.
     * Isso garante que você gerencie produtos, clientes e TODOS os pedidos sem erros de permissão.
     */
    match /artifacts/docuras-da-fran-default/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    /**
     * 2. REGRAS PÚBLICAS (PARA A LOJA ONLINE - VISITANTES ANÔNIMOS)
     * Permite que clientes não logados vejam o cardápio e criem pedidos.
     */
    
    // Visitantes podem ler produtos, categorias, opcionais e configurações para ver o cardápio
    match /artifacts/docuras-da-fran-default/products/{id} {
      allow read: if true;
    }
    match /artifacts/docuras-da-fran-default/product-categories/{id} {
      allow read: if true;
    }
    match /artifacts/docuras-da-fran-default/optionals/{id} {
      allow read: if true;
    }
    match /artifacts/docuras-da-fran-default/settings/app {
      allow read: if true;
    }

    // Visitantes podem criar/atualizar seu cadastro de cliente na loja
    match /artifacts/docuras-da-fran-default/customers/{id} {
      allow read, write: if true;
    }

    // Visitantes podem CRIAR pedidos (transações) anonimamente.
    // O Admin (pela regra mestre acima) tem permissão de UPDATE/DELETE.
    match /artifacts/docuras-da-fran-default/users/{userId}/transactions/{id} {
      allow create: if true;
    }
    
    // Suporte para consultas em nível de grupo de coleções (relatórios e dashboard)
    match /{path=**}/transactions/{id} {
      allow read, write: if request.auth != null;
    }
  }
}