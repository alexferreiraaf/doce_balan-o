rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSuperAdmin() {
      return request.auth != null && request.auth.uid == 'I7HKJVmF4uRDL75dQShPmHVi4333';
    }

    function isAdmin() {
      return isSuperAdmin() || (
        request.auth != null && 
        exists(/databases/$(database)/documents/artifacts/docuras-da-fran-default/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/artifacts/docuras-da-fran-default/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // 1. ACESSO ADMINISTRATIVO
    match /artifacts/docuras-da-fran-default/{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // 2. ACESSO PÚBLICO (Loja Online / Visitantes)
    
    // Produtos e Categorias: Todos podem ver
    match /artifacts/docuras-da-fran-default/products/{id} {
      allow read: if true;
    }
    match /artifacts/docuras-da-fran-default/product-categories/{id} {
      allow read: if true;
    }
    match /artifacts/docuras-da-fran-default/optionals/{id} {
      allow read: if true;
    }
    match /artifacts/docuras-da-fran-default/settings/app {
      allow read: if true;
    }
    
    // Clientes: Público só pode criar (Storefront), Admin pode tudo
    match /artifacts/docuras-da-fran-default/customers/{id} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
    
    // Transações/Pedidos: Público só pode criar (Storefront), Admin pode tudo
    match /artifacts/docuras-da-fran-default/users/{userId}/transactions/{id} {
      allow create: if true;
      allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
    }
  }
}