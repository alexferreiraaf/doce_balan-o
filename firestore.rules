rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: O usuário está autenticado no sistema?
    function isLogged() {
      return request.auth != null && request.auth.uid != null;
    }

    // 1. ACESSO ADMINISTRATIVO GLOBAL
    // Permite que qualquer usuário logado (você, o administrador) tenha acesso total
    // a todos os dados do aplicativo. Isso é essencial para o Kanban e gestão financeira.
    match /artifacts/{appId}/{document=**} {
      allow read, write: if isLogged();
    }

    // 2. ACESSO PÚBLICO / LOJA VIRTUAL
    // Permissões específicas para clientes que acessam o cardápio sem login.
    
    // Produtos, Categorias e Opcionais: Leitura pública para exibir o cardápio.
    match /artifacts/{appId}/products/{productId} {
      allow read: if true;
    }
    match /artifacts/{appId}/product-categories/{categoryId} {
      allow read: if true;
    }
    match /artifacts/{appId}/optionals/{optionalId} {
      allow read: if true;
    }

    // Configurações da Loja: Leitura pública para verificar horário e chave PIX.
    match /artifacts/{appId}/settings/app {
      allow read: if true;
    }

    // Clientes: Permite que a loja identifique ou cadastre clientes pelo WhatsApp.
    match /artifacts/{appId}/customers/{customerId} {
      allow read, create, update: if true;
    }

    // Pedidos (Transações): Clientes anônimos podem criar pedidos.
    // O gerenciamento (leitura/atualização) é feito pelo Admin via regra global acima.
    match /artifacts/{appId}/users/{userId}/transactions/{transactionId} {
      allow create: if true;
    }
    
    // Suporte para consultas em nível de grupo de coleções (Necessário para o Painel)
    match /{path=**}/transactions/{transactionId} {
      allow read, write: if isLogged();
    }
  }
}