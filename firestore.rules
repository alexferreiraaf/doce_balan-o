rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. REGRA ADMINISTRATIVA (Prioridade Máxima)
    // Se o usuário estiver logado, ele tem poder total sobre todos os documentos do app.
    match /artifacts/docuras-da-fran-default/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // 2. REGRAS DA LOJA ONLINE (Acesso Público/Anônimo)
    // Visitantes precisam ler produtos e configurações para navegar na loja.
    match /artifacts/docuras-da-fran-default/products/{id} {
      allow read: if true;
    }
    match /artifacts/docuras-da-fran-default/product-categories/{id} {
      allow read: if true;
    }
    match /artifacts/docuras-da-fran-default/optionals/{id} {
      allow read: if true;
    }
    match /artifacts/docuras-da-fran-default/settings/app {
      allow read: if true;
    }

    // Visitantes podem criar e atualizar seus próprios dados de cliente (para checkout).
    match /artifacts/docuras-da-fran-default/customers/{id} {
      allow read, write: if true;
    }

    // Visitantes podem criar novos pedidos (transactions).
    match /artifacts/docuras-da-fran-default/users/{userId}/transactions/{id} {
      allow create: if true;
    }
    
    // 3. REGRAS DE CONSULTA GLOBAL (Collection Groups)
    // Necessário para buscas transversais em subcoleções.
    match /{path=**}/transactions/{id} {
      allow read, write: if request.auth != null;
    }
  }
}