rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: O usuário está autenticado no sistema?
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    // 1. REGRA DE ADMINISTRADOR (ACESSO TOTAL)
    // Se o usuário estiver logado, ele tem permissão total sobre todos os artefatos.
    // Isso garante que o admin possa editar pedidos da loja, cadastros e relatórios.
    match /artifacts/docuras-da-fran-default/{allPaths=**} {
      allow read, write: if isAuthenticated();
    }

    // 2. REGRAS PÚBLICAS (PARA A LOJA ONLINE)
    // Permite que clientes não logados acessem informações básicas para fazer pedidos.
    match /artifacts/docuras-da-fran-default/products/{id} {
      allow read: if true;
    }
    match /artifacts/docuras-da-fran-default/product-categories/{id} {
      allow read: if true;
    }
    match /artifacts/docuras-da-fran-default/optionals/{id} {
      allow read: if true;
    }
    match /artifacts/docuras-da-fran-default/settings/app {
      allow read: if true;
    }
    match /artifacts/docuras-da-fran-default/customers/{id} {
      allow read, write: if true;
    }

    // Permite que a loja crie pedidos (transações) anonimamente.
    // O admin terá acesso a esses pedidos pela Regra 1 acima.
    match /artifacts/docuras-da-fran-default/users/{userId}/transactions/{id} {
      allow create: if true;
    }
    
    // Suporte para consultas em nível de grupo de coleções (usado em relatórios)
    match /{path=**}/transactions/{id} {
      allow read, write: if isAuthenticated();
    }
  }
}