rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * 1. ACESSO ADMINISTRATIVO TOTAL
     * Se o usuário estiver autenticado (logado), ele tem permissão total
     * para ler e escrever em QUALQUER documento dentro do app.
     */
    match /artifacts/docuras-da-fran-default/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    /**
     * 2. REGRAS PARA A LOJA ONLINE (VISITANTES ANÔNIMOS)
     * Permite que clientes não logados interajam com o cardápio e façam pedidos.
     */
    
    // Visitantes podem ver produtos, categorias e configurações
    match /artifacts/docuras-da-fran-default/products/{id} {
      allow read: if true;
    }
    match /artifacts/docuras-da-fran-default/product-categories/{id} {
      allow read: if true;
    }
    match /artifacts/docuras-da-fran-default/optionals/{id} {
      allow read: if true;
    }
    match /artifacts/docuras-da-fran-default/settings/app {
      allow read: if true;
    }

    // Visitantes podem criar e atualizar seus próprios dados de cliente
    match /artifacts/docuras-da-fran-default/customers/{id} {
      allow read, write: if true;
    }

    // Visitantes podem CRIAR pedidos (transações)
    match /artifacts/docuras-da-fran-default/users/{userId}/transactions/{id} {
      allow create: if true;
    }
    
    // Suporte para consultas em nível de grupo de coleções
    match /{path=**}/transactions/{id} {
      allow read, write: if request.auth != null;
    }
  }
}