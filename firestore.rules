rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // TRANSAÇÕES
    // Permitir que qualquer pessoa crie (necessário para a loja virtual)
    // Permitir que usuários logados (administradores) leiam e modifiquem TUDO
    match /artifacts/{appId}/users/{userId}/transactions/{transactionId} {
      allow create: if true;
      allow read, write: if request.auth != null;
    }

    // COLEÇÕES PÚBLICAS (Produtos, Categorias, Clientes, Opcionais)
    // Qualquer um pode ler, apenas logados podem escrever.
    match /artifacts/{appId}/products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /artifacts/{appId}/customers/{customerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /artifacts/{appId}/product-categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /artifacts/{appId}/optionals/{optionalId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Configurações
    match /artifacts/{appId}/settings/app {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Suporte para consultas globais e modificações por administradores
    match /{path=**}/transactions/{transactionId} {
      allow read, write: if request.auth != null;
    }
  }
}