rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // TRANSAÇÕES
    // Permitir que qualquer pessoa crie transações (necessário para pedidos da loja virtual)
    // Permitir que usuários autenticados (administradores) leiam e modifiquem todas as transações
    match /artifacts/{appId}/users/{userId}/transactions/{transactionId} {
      allow create: if true;
      allow read, update, delete: if isSignedIn();
    }

    // COLEÇÕES PÚBLICAS (Produtos, Categorias, Clientes, Opcionais)
    // Qualquer pessoa pode ler os dados para navegar na loja, mas apenas administradores podem modificar.
    
    match /artifacts/{appId}/products/{productId} {
      allow get, list: if true;
      allow write: if isSignedIn();
    }

    match /artifacts/{appId}/customers/{customerId} {
      allow get, list: if true;
      allow write: if isSignedIn();
    }
    
    match /artifacts/{appId}/product-categories/{categoryId} {
      allow get, list: if true;
      allow write: if isSignedIn();
    }

    match /artifacts/{appId}/optionals/{optionalId} {
      allow get, list: if true;
      allow write: if isSignedIn();
    }

    // Configurações podem ser lidas por qualquer um (para ver chave PIX e horários), 
    // mas editadas apenas por administradores logados.
    match /artifacts/{appId}/settings/app {
      allow get: if true;
      allow write: if isSignedIn();
    }
    
    // Suporte para consulta de grupo de coleções (Collection Group Queries) para o administrador.
    match /{path=**}/transactions/{transactionId} {
      allow list: if isSignedIn();
    }
  }
}