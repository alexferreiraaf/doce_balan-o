rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: O usuário está autenticado no sistema?
    function isLogged() {
      return request.auth != null && request.auth.uid != null;
    }

    // 1. ACESSO ADMINISTRATIVO GLOBAL
    // Permite que qualquer usuário logado (o administrador) tenha acesso total
    // a todos os dados do aplicativo, independentemente do sub-caminho.
    match /artifacts/{appId}/{document=**} {
      allow read, write: if isLogged();
    }

    // 2. ACESSO PÚBLICO / LOJA VIRTUAL
    // Permissões específicas para clientes que acessam o cardápio sem login.
    
    match /artifacts/{appId}/products/{productId} {
      allow read: if true;
    }
    match /artifacts/{appId}/product-categories/{categoryId} {
      allow read: if true;
    }
    match /artifacts/{appId}/optionals/{optionalId} {
      allow read: if true;
    }
    match /artifacts/{appId}/settings/app {
      allow read: if true;
    }
    match /artifacts/{appId}/customers/{customerId} {
      allow read, create, update: if true;
    }

    // Pedidos (Transações)
    match /artifacts/{appId}/users/{userId}/transactions/{transactionId} {
      // Clientes anônimos podem criar pedidos (Storefront)
      allow create: if true;
      // O Admin logado pode gerenciar todos os pedidos (Kanban/Painel)
      allow read, update, delete: if isLogged();
    }
    
    // Suporte para consultas em nível de grupo de coleções
    match /{path=**}/transactions/{transactionId} {
      allow read, write: if isLogged();
    }
  }
}