rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. REGRA DE ADMIN (USUÁRIOS AUTENTICADOS)
    // Qualquer pessoa logada tem permissão TOTAL de leitura e escrita 
    // em qualquer documento dentro da pasta do aplicativo.
    match /artifacts/docuras-da-fran-default/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid != null;
    }

    // 2. REGRAS PÚBLICAS (PARA A LOJA ONLINE - VISITANTES)
    // Permite que clientes não logados acessem o cardápio e criem pedidos.
    
    match /artifacts/docuras-da-fran-default/products/{id} {
      allow read: if true;
    }
    match /artifacts/docuras-da-fran-default/product-categories/{id} {
      allow read: if true;
    }
    match /artifacts/docuras-da-fran-default/optionals/{id} {
      allow read: if true;
    }
    match /artifacts/docuras-da-fran-default/settings/app {
      allow read: if true;
    }
    match /artifacts/docuras-da-fran-default/customers/{id} {
      allow read, write: if true;
    }

    // Permite que a loja crie pedidos (transações) anonimamente.
    match /artifacts/docuras-da-fran-default/users/{userId}/transactions/{id} {
      allow create: if true;
    }
    
    // Suporte para consultas em nível de grupo de coleções
    match /{path=**}/transactions/{id} {
      allow read, write: if request.auth != null;
    }
  }
}
