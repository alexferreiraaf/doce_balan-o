rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: O usuário está autenticado?
    function isLogged() {
      return request.auth != null && request.auth.uid != null;
    }

    // ACESSO ADMINISTRATIVO GLOBAL
    // Permite que qualquer usuário logado (administrador) tenha acesso total a todos os dados do app.
    // Isso garante que você possa gerenciar pedidos, produtos e clientes sem erros de permissão.
    match /artifacts/{appId}/{document=**} {
      allow read, write: if isLogged();
    }

    // ACESSO PÚBLICO (LOJA VIRTUAL)
    // Permissões específicas para clientes anônimos que acessam a loja.
    
    // Pedidos (Transações)
    match /artifacts/{appId}/users/{userId}/transactions/{transactionId} {
      allow create: if true; // Clientes anônimos criam pedidos na loja
      allow read, write: if isLogged(); // Admin gerencia totalmente
    }

    // Cardápio (Produtos, Categorias e Opcionais)
    match /artifacts/{appId}/products/{productId} {
      allow read: if true;
    }
    match /artifacts/{appId}/product-categories/{categoryId} {
      allow read: if true;
    }
    match /artifacts/{appId}/optionals/{optionalId} {
      allow read: if true;
    }

    // Clientes (Identificação na loja)
    match /artifacts/{appId}/customers/{customerId} {
      allow read, create, update: if true;
    }

    // Configurações da Loja
    match /artifacts/{appId}/settings/app {
      allow read: if true;
    }
    
    // Suporte para consultas em nível de coleção para o Admin
    match /{path=**}/transactions/{transactionId} {
      allow read, write: if isLogged();
    }
  }
}