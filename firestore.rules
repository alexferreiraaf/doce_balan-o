rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: O usuário está logado no sistema?
    function isLogged() {
      return request.auth != null;
    }

    // ACESSO ADMINISTRATIVO GLOBAL
    // Qualquer usuário autenticado (o administrador) pode ler e escrever em qualquer documento dentro de 'artifacts'.
    // Isso resolve o erro de permissão ao gerenciar pedidos da loja no Kanban.
    match /artifacts/{appId}/{document=**} {
      allow read, write: if isLogged();
    }

    // ACESSO PÚBLICO (LOJA VIRTUAL)
    // Permissões necessárias para que clientes anônimos façam pedidos e vejam o cardápio.
    
    // Pedidos (Transações)
    match /artifacts/{appId}/users/{userId}/transactions/{transactionId} {
      allow create: if true; // Clientes anônimos criam pedidos
    }

    // Cardápio (Produtos, Categorias e Opcionais)
    match /artifacts/{appId}/products/{productId} {
      allow read: if true;
    }
    match /artifacts/{appId}/product-categories/{categoryId} {
      allow read: if true;
    }
    match /artifacts/{appId}/optionals/{optionalId} {
      allow read: if true;
    }

    // Clientes (Necessário para a loja identificar/cadastrar o cliente ao finalizar pedido)
    match /artifacts/{appId}/customers/{customerId} {
      allow read, create, update: if true;
    }

    // Configurações da Loja (PIX, Horários, etc)
    match /artifacts/{appId}/settings/app {
      allow read: if true;
    }
    
    // Suporte para consultas globais de administradores
    match /{path=**}/transactions/{transactionId} {
      allow read, write: if isLogged();
    }
  }
}