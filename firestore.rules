rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Permitir que usuários logados (administradores) listem, leiam, excluam e atualizem transações.
    // Isso é necessário para que o painel administrativo possa gerenciar pedidos da loja
    // que foram criados sob o ID do usuário da vitrine.
    match /artifacts/{appId}/users/{userId}/transactions/{transactionId} {
      allow list, get, delete, update: if isSignedIn();
      allow create: if true; // Permite que a loja crie pedidos anonimamente
    }

    // COLEÇÕES PÚBLICAS
    // Permite que qualquer pessoa veja produtos, mas apenas administradores gerenciem.
    match /artifacts/{appId}/products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    // Permite que qualquer pessoa veja clientes (necessário para o checkout), mas apenas administradores gerenciem.
    match /artifacts/{appId}/customers/{customerId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }
    
    // Permite que qualquer pessoa veja categorias, mas apenas administradores gerenciem.
    match /artifacts/{appId}/product-categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    // Permite que qualquer pessoa veja opcionais, mas apenas administradores gerenciem.
    match /artifacts/{appId}/optionals/{optionalId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    // Configurações podem ser lidas por qualquer um (para chave PIX), mas editadas apenas por administradores.
    match /artifacts/{appId}/settings/app {
      allow get: if true;
      allow write: if isSignedIn();
    }
    
    // Consulta de grupo de coleções para o administrador.
    match /{path=**}/transactions/{transactionId} {
      allow list: if isSignedIn();
    }
  }
}
