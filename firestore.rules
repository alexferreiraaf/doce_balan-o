rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * REGRAS DE SEGURANÇA - DOÇURAS DA FRAN
     */

    // Permissão administrativa total para usuários logados
    // Qualquer pessoa autenticada pode gerenciar todos os dados do app em /artifacts/
    match /artifacts/docuras-da-fran-default/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Regras específicas para a Loja Online (Visitantes Anônimos)
    // Visitantes podem ler produtos, categorias e configurações
    match /artifacts/docuras-da-fran-default/products/{id} {
      allow read: if true;
    }
    match /artifacts/docuras-da-fran-default/product-categories/{id} {
      allow read: if true;
    }
    match /artifacts/docuras-da-fran-default/optionals/{id} {
      allow read: if true;
    }
    match /artifacts/docuras-da-fran-default/settings/app {
      allow read: if true;
    }

    // Visitantes podem criar e atualizar seus próprios dados de cliente
    match /artifacts/docuras-da-fran-default/customers/{id} {
      allow read, write: if true;
    }

    // Visitantes podem criar novos pedidos
    match /artifacts/docuras-da-fran-default/users/{userId}/transactions/{id} {
      allow create: if true;
    }
    
    // Suporte para consultas em nível de grupo de coleções (Collection Group Queries)
    match /{path=**}/transactions/{id} {
      allow read, write: if request.auth != null;
    }
  }
}