rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: O usuário está autenticado?
    function isLogged() {
      return request.auth != null && request.auth.uid != null;
    }

    // 1. ACESSO TOTAL PARA ADMINISTRADOR
    // Qualquer usuário logado tem permissão total em todos os artefatos do app.
    // Isso garante que o Kanban e os relatórios funcionem sem erros de permissão.
    match /artifacts/{appId}/{document=**} {
      allow read, write: if isLogged();
    }

    // 2. ACESSO PÚBLICO (LOJA VIRTUAL)
    // Permissões específicas para clientes não logados.
    
    match /artifacts/{appId}/products/{productId} {
      allow read: if true;
    }
    match /artifacts/{appId}/product-categories/{categoryId} {
      allow read: if true;
    }
    match /artifacts/{appId}/optionals/{optionalId} {
      allow read: if true;
    }
    match /artifacts/{appId}/settings/app {
      allow read: if true;
    }
    match /artifacts/{appId}/customers/{customerId} {
      allow read, write: if true;
    }

    // Pedidos (Transações)
    // Permite que a loja crie pedidos anonimamente.
    match /artifacts/{appId}/users/{userId}/transactions/{transactionId} {
      allow create: if true;
    }
    
    // Suporte para consultas em nível de grupo de coleções
    match /{path=**}/transactions/{transactionId} {
      allow read, write: if isLogged();
    }
  }
}